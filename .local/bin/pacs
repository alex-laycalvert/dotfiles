#!/bin/bash
# 
# https://github.com/alex-laycalvert
#
# Script to search both pacman and yay AUR helper
# 

if [[ $1 = "" ]]; then
    echo -e "A script to search the package manager pacman and AUR helper yay together\n"
    echo "Usage:"
    echo -e "    pacs <package>\n"
    echo "Example:"
    echo -e "    pacs neovim\n"
    exit 0
fi

PACMAN_RESULTS=`pacman -Ss $1`

bold=$(tput bold)
norm=$(tput sgr0)

while IFS= read -r line; do
    trimmed_line="${line:4}"
    [[ $line = "    "* ]] && echo "         └─ $trimmed_line" || echo "${bold}PACMAN: ${norm}$line"
done < <(printf '%s\n' "$PACMAN_RESULTS")

YAY_RESULTS=`yay -Ss $1`

while IFS= read -r line; do
    trimmed_line="${line:4}"
    [[ $line = "    "* ]] && echo "      └─ $trimmed_line" || echo "${bold}YAY: ${norm}$line"
done < <(printf '%s\n' "$YAY_RESULTS")
