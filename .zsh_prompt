## PROMPT
#
#
# Custom prompt
# %/ %d = current dir
# %~ = current dir with ~ for home
# %l = tty
# %M = full hostname
# %m = hostname up to '.'
# %n = username
# %# = shell privilege state
# %i = shell line number
# %j = number of jobs
# %D = date in yy-mm-dd
# %T = time in 24 hr format
# %t %@ = time in 12 hr format am/pm
# %* = time in 24 hr format with seconds
# %w = date in day-dd
# %W = date in mm/dd/yy
# %D{string} = date in strftime format of string
# %B %b = start/stop bold
# %E = clear to end of line
# %U %u = start/stop underline
# %S %s = start/stop standout 
# %F{color} %f = start/stop foreground color
# %K{color} %k = start/stop background color
# %(X.true-text.false-text) = ternary op
#

setopt PROMPT_SUBST
setopt PROMPT_PERCENT
setopt PROMPT_BANG

SEG_SEP=''
PIXEL_SQ=''
RSEG_SEP=''
GIT_SYMBOL=''
STATUS_GOOD=''
STATUS_BAD='×'
RAINBOW_PROMPT="%K{black}      %k%K{red}%F{black}%f      %k%K{green}%F{red}%f      %k%K{yellow}%F{green}%f      %k%K{blue}%F{yellow}%f      %k%K{magenta}%F{blue}%f      %k%K{cyan}%F{magenta}%f      %k%K{white}%F{cyan}%f      %k%F{white}%f "

function create_prompt {
    local tmp_prompt=""  
    for i in {1..$#..4}
    do
        local bg_color=${@:$i:1}
        local fg_color=${@:$i+1:1}
        local text=${@:$i+2:1}
        local seg_sep=${@:$i+3:1}
        tmp_prompt=$tmp_prompt"%K{$bg_color}%F{$fg_color}$text%f%k"
        if [[ $i -ne `expr $# - 3` ]]; then
            local next_bg_color=${@:$i+4:1}
            tmp_prompt=$tmp_prompt"%K{$next_bg_color}%F{$bg_color}$seg_sep%f%k"
        else
            tmp_prompt=$tmp_prompt"%F{$bg_color}$seg_sep%f"
        fi
    done
    echo $tmp_prompt
}

function create_rprompt {
    local tmp_prompt=""  
    for i in {1..$#..4}
    do
        local bg_color=${@:$i:1}
        local fg_color=${@:$i+1:1}
        local text=${@:$i+2:1}
        local seg_sep=${@:$i+3:1}
        if [[ $i -ne 1 ]]; then
            local prev_bg_color=${@:$i-4:1}
            tmp_prompt=$tmp_prompt"%K{$prev_bg_color}%F{$bg_color}$seg_sep%f%k"
        else
            tmp_prompt="%F{$bg_color}$seg_sep%f"
        fi
        tmp_prompt=$tmp_prompt"%K{$bg_color}%F{$fg_color}$text%f%k"
    done
    echo $tmp_prompt
}

autoload -Uz vcs_info
zstyle ':vcs_info:git:*' formats "on $GIT_SYMBOL %b"

function preexec {
  timer=${timer:-$SECONDS}
}

function precmd {
    vcs_info
    if [[ -z "${vcs_info_msg_0_// }" ]]; then
        PROMPT="$(create_prompt '#303035' blue ' %n@%m ' $SEG_SEP blue black ' %~ ' $SEG_SEP) "
    else
        PROMPT="$(create_prompt '#303035' blue ' %n@%m ' $SEG_SEP blue black ' %~ ' $SEG_SEP '#303035' blue " $vcs_info_msg_0_ " $SEG_SEP) "
    fi
    #if [ $timer ]; then
    #   timer_show=$(($SECONDS - $timer))
    #   RPROMPT='$(create_rprompt black white "%{0?.$STATUS_GOOD.$STATUS_BAD%}" $RSEG_SEP white black $timer_show $RSEG_SEP)'
    #   RPROMPT="%F{white}$RSEG_SEP%f%K{white}%%F{black}{0?.$STATUS_GOOD.$STATUS_BAD%}%f%F{white}$RSEG_SEP%f%k%K{white}%F{black}$timer_show%f%k"
    #   unset timer
    #fi
}

